# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FaceAttend

# Face Recognition (optional external services)
# COMPRE_FACE_URL=http://localhost:8000
# COMPRE_FACE_API_KEY=

# Map
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key  # optional, OSM free tiles work too
NEXT_PUBLIC_MAP_STYLE=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# Retention
BIOMETRIC_MEDIA_RETENTION_DAYS=7
AUDIT_LOG_RETENTION_DAYS=365

# Security
SESSION_EXPIRY_MINUTES=480
MAX_CLOCK_DISTANCE_M=50000
MAX_LOCATION_AGE_SECONDS=30
RISK_HIGH_THRESHOLD=80
RISK_REVIEW_THRESHOLD=60
